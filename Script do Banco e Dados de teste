-- 1) usuario
CREATE TABLE IF NOT EXISTS usuario (
    id_usuario SERIAL PRIMARY KEY,
    nome VARCHAR(100) NOT NULL
);

-- 2) midia
CREATE TABLE IF NOT EXISTS midia (
    id_midia SERIAL PRIMARY KEY,
    titulo VARCHAR(150) NOT NULL,
    genero VARCHAR(50) NOT NULL,
    ano INT NOT NULL,
    duracao INT,
    class_indicativa VARCHAR(10),
    elenco VARCHAR(250),
    nota_media DECIMAL
);

-- 3) serie
CREATE TABLE IF NOT EXISTS serie (
    id_midia INTEGER PRIMARY KEY,
    CONSTRAINT fk_serie_midia
        FOREIGN KEY (id_midia)
        REFERENCES midia(id_midia)
        ON UPDATE CASCADE
        ON DELETE CASCADE
);

-- 4) temporada
CREATE TABLE IF NOT EXISTS temporada (
    id_temporada SERIAL PRIMARY KEY,
    id_serie INTEGER NOT NULL,
    numero_temporada INT NOT NULL,
    CONSTRAINT fk_temporada_serie
        FOREIGN KEY (id_serie)
        REFERENCES serie(id_midia)
        ON UPDATE CASCADE
        ON DELETE CASCADE
);

-- 5) episodio
CREATE TABLE IF NOT EXISTS episodio (
    id_episodio SERIAL PRIMARY KEY,
    id_temporada INTEGER NOT NULL,
    numero_episodio INT NOT NULL,
    titulo VARCHAR(150),
    duracao_minutos INT,
    data_lancamento DATE,
    status VARCHAR(20),
    nota DECIMAL,
    CONSTRAINT fk_episodio_temporada
        FOREIGN KEY (id_temporada)
        REFERENCES temporada(id_temporada)
        ON UPDATE CASCADE
        ON DELETE CASCADE
);

-- 6) lista_personalizada
CREATE TABLE IF NOT EXISTS lista_personalizada (
    id_lista SERIAL PRIMARY KEY,
    id_usuario INTEGER NOT NULL,
    nome_lista VARCHAR(50),
    CONSTRAINT fk_lista_usuario
        FOREIGN KEY (id_usuario)
        REFERENCES usuario(id_usuario)
        ON UPDATE CASCADE
        ON DELETE CASCADE
);

-- 7) lista_midia
CREATE TABLE IF NOT EXISTS lista_midia (
    id_lista INTEGER NOT NULL,
    id_midia INTEGER NOT NULL,
    CONSTRAINT pk_lista_midia PRIMARY KEY (id_lista, id_midia),
    CONSTRAINT fk_lista_midia_lista
        FOREIGN KEY (id_lista)
        REFERENCES lista_personalizada(id_lista)
        ON UPDATE CASCADE
        ON DELETE CASCADE,
    CONSTRAINT fk_lista_midia_midia
        FOREIGN KEY (id_midia)
        REFERENCES midia(id_midia)
        ON UPDATE CASCADE
        ON DELETE CASCADE
);

-- 8) usuario_midia
CREATE TABLE IF NOT EXISTS usuario_midia (
    id_usuario INTEGER NOT NULL,
    id_midia INTEGER NOT NULL,
    status VARCHAR(20),
    nota DECIMAL,
    data_conclusao DATE,
    CONSTRAINT pk_usuario_midia PRIMARY KEY (id_usuario, id_midia),
    CONSTRAINT fk_usuario_midia_usuario
        FOREIGN KEY (id_usuario)
        REFERENCES usuario(id_usuario)
        ON UPDATE CASCADE
        ON DELETE CASCADE,
    CONSTRAINT fk_usuario_midia_midia
        FOREIGN KEY (id_midia)
        REFERENCES midia(id_midia)
        ON UPDATE CASCADE
        ON DELETE CASCADE
);


