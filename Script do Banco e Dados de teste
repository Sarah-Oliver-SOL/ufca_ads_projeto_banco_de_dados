-- ==========================================================
-- VIEW (vw)
-- ==========================================================
-- Busca facilitar uma consulta muito frequente do sistema:"histórico do usuário"
-- com dados da mídia (JOIN entre usuario_midia + usuario + midia).
-- Assim o sistema consulta a VIEW em vez de repetir SELECT com JOIN toda hora.
-- Obs: Uso do "OR REPLACE", para que caso a função exista, seja substituída pela nova.
CREATE OR REPLACE VIEW vw_historico_usuario AS
SELECT
    u.id_usuario,
    u.nome AS usuario,
    m.id_midia,
    m.titulo,
    m.genero,
    m.ano,
    um.status,
    um.nota AS nota_usuario,
    um.data_conclusao
FROM usuario_midia um
INNER JOIN usuario u
    ON u.id_usuario = um.id_usuario
INNER JOIN midia m
    ON m.id_midia = um.id_midia;


-- ==========================================================
-- VIEW MATERIALIZADA (mv)
-- ==========================================================
-- Gera um relatório agregado por gênero, evitando recalcular contagens e médias repetidamente.
DROP MATERIALIZED VIEW IF EXISTS mv_relatorio_genero;

CREATE MATERIALIZED VIEW mv_relatorio_genero AS
SELECT
    m.genero,
    COUNT(DISTINCT m.id_midia) AS total_midias,
    AVG(m.nota_media)          AS media_nota_catalogo,
    AVG(um.nota)               AS media_nota_usuarios,
    COUNT(um.id_usuario)       AS total_avaliacoes
FROM midia m
LEFT JOIN usuario_midia um
    ON um.id_midia = m.id_midia
GROUP BY m.genero;

-- Índice simples para consultas rápidas por gênero na MV
CREATE INDEX IF NOT EXISTS idx_mv_relatorio_genero_genero
ON mv_relatorio_genero (genero);


