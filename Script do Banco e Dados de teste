-- ==========================================================
-- 4) Regras ON DELETE / ON UPDATE
-- ==========================================================

-- (FK 1) lista_personalizada -> usuario
-- RESTRICT (não permitir apagar usuário se ainda tiver listas)
-- A chave estrangeira entre lista_personalizada e usuario é recriada com 
-- ON DELETE RESTRICT, impedindo a exclusão de usuários que ainda possuem listas cadastradas. 
-- Isso evita perda acidental de dados e mantém a integridade referencial do sistema. 
-- O uso de ON UPDATE CASCADE garante que eventuais alterações no identificador do usuário sejam 
-- propagadas automaticamente para as listas associadas.
ALTER TABLE lista_personalizada
DROP CONSTRAINT fk_lista_usuario;

ALTER TABLE lista_personalizada
ADD CONSTRAINT fk_lista_usuario
FOREIGN KEY (id_usuario)
REFERENCES usuario(id_usuario)
ON UPDATE CASCADE
ON DELETE RESTRICT;

-- (FK 2) usuario_midia -> usuario
-- UPDATE CASCADE: se o id_usuario mudar na tabela usuario, é atualizado em usuario_midia, 
-- preservando a integridade referencial.
-- DELETE CASCADE: se apagar o usuario, apaga-se automaticamente o histórico dele. 
-- Ou seja, evita-se registros órfãos
ALTER TABLE usuario_midia
DROP CONSTRAINT fk_usuario_midia_usuario;

ALTER TABLE usuario_midia
ADD CONSTRAINT fk_usuario_midia_usuario
FOREIGN KEY (id_usuario)
REFERENCES usuario(id_usuario)
ON UPDATE CASCADE
ON DELETE CASCADE;

