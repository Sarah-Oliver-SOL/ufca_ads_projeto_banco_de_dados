-- TRIGGERS
-- ==========================================================

-- ----------------------------------------------------------
-- Trigger BEFORE (em usuario_midia)
-- ----------------------------------------------------------
-- Faz a validação/ajuste antes de inserir/atualizar.
-- Regras simples e coerentes:
-- 1) padroniza status para MAIÚSCULO
-- 2) impede status inválido
-- 3) valida nota (0 a 10) quando preenchida
-- 4) se status for CONCLUIDO e data_conclusao vier NULL, define automaticamente com a data atual (CURRENT DATE)
CREATE OR REPLACE FUNCTION fn_usuario_midia_before_validar()
RETURNS trigger

LANGUAGE plpgsql
AS $$
BEGIN
    -- Padronização do status
    IF NEW.status IS NOT NULL THEN
        NEW.status := upper(NEW.status);
    END IF;

    -- Validação do status permitido
    IF NEW.status IS NOT NULL AND NEW.status NOT IN
        ('NAO_INICIADO', 'ASSISTINDO', 'ASSISTIDO', 'CONCLUIDO')
    THEN
        RAISE EXCEPTION 'Status inválido em usuario_midia: %', NEW.status;
    END IF;

    -- Validação da nota de usuário (se preenchida)
    IF NEW.nota IS NOT NULL AND (NEW.nota < 0 OR NEW.nota > 10) THEN
        RAISE EXCEPTION 'Nota inválida em usuario_midia (0 a 10): %', NEW.nota;
    END IF;

    -- Auto-preenchimento da data de conclusão, quando necessário
    IF NEW.status = 'CONCLUIDO' AND NEW.data_conclusao IS NULL THEN
        NEW.data_conclusao := CURRENT_DATE;
    END IF;

    RETURN NEW;
END;
$$;

DROP TRIGGER IF EXISTS trg_usuario_midia_before_validar ON usuario_midia;

CREATE TRIGGER trg_usuario_midia_before_validar
BEFORE INSERT OR UPDATE ON usuario_midia
FOR EACH ROW
EXECUTE FUNCTION fn_usuario_midia_before_validar();


-- ----------------------------------------------------------
-- Trigger AFTER (log de ações em usuario_midia)
-- ----------------------------------------------------------
-- Busca registrar log simples após inserções no histórico do usuário.
-- Por exemplo, toda vez que o usuário adicionar uma mídia, cria um registro no log.
CREATE TABLE IF NOT EXISTS log_usuario_midia (
    id_log SERIAL PRIMARY KEY,
    id_usuario INT NOT NULL,
    id_midia INT NOT NULL,
    acao VARCHAR(20) NOT NULL,
    status VARCHAR(20),
    data_evento TIMESTAMP NOT NULL DEFAULT now()
);

CREATE OR REPLACE FUNCTION fn_usuario_midia_after_log()
RETURNS trigger

LANGUAGE plpgsql
AS $$
BEGIN
    INSERT INTO log_usuario_midia (id_usuario, id_midia, acao, status)
    VALUES (NEW.id_usuario, NEW.id_midia, 'INSERT', NEW.status);

    RETURN NEW;
END;
$$;

DROP TRIGGER IF EXISTS trg_usuario_midia_after_log ON usuario_midia;

CREATE TRIGGER trg_usuario_midia_after_log
AFTER INSERT ON usuario_midia
FOR EACH ROW
EXECUTE FUNCTION fn_usuario_midia_after_log();


-- ==========================================================
-- PROCEDURE
-- ==========================================================
-- Rotina administrativa para manutenção.
-- Recalcula nota_media da tabela midia com base nas notas dadas pelos usuários.
CREATE OR REPLACE PROCEDURE sp_recalcular_nota_media_midias()
LANGUAGE plpgsql
AS $$
BEGIN
    UPDATE midia m
    SET nota_media = sub.media_calc
    FROM (
        SELECT id_midia, ROUND(AVG(nota)::numeric, 1) AS media_calc
        FROM usuario_midia
        WHERE nota IS NOT NULL
        GROUP BY id_midia
    ) sub
    WHERE m.id_midia = sub.id_midia;

 -- Se uma mídia não tiver notas em usuario_midia, a nota_media fica como está (ou vazia).
END;
$$;

