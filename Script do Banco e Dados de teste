  lp.nome_lista,
  m.titulo,
  m.genero,
  m.ano
FROM lista_midia lm
INNER JOIN lista_personalizada lp
  ON lp.id_lista = lm.id_lista
INNER JOIN midia m
  ON m.id_midia = lm.id_midia
WHERE lp.id_lista = 1;


-- Consulta 3: Histórico de mídias assistidas pelo usuário 1 |(Sarah)
